<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mi Tarjeta de Perfil</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: sans-serif;
      background: #f5f5f5;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* Tarjeta principal */
    .tarjeta {
      background: white;
      width: 320px;
      padding: 20px;
      border-radius: 15px;
      display: flex;
      flex-direction: column; /* ✅ */
      gap: 15px; /* ✅ */
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    /* Header */
    .perfil-header {
      display: flex; /* ✅ */
      align-items: center; /* ✅ */
      gap: 15px; /* ✅ */
    }

    .perfil-header img {
      width: 70px;
      height: 70px;
      border-radius: 50%;
    }

    .info {
      display: flex; /* ✅ */
      flex-direction: column; /* ✅ */
      justify-content: center;
    }

    .info h2 {
      font-size: 18px;
    }

    .info span {
      color: gray;
      font-size: 14px;
    }

    /* Bio */
    .bio {
      font-size: 14px;
      color: #555;
      text-align: center;
    }

    /* Estadísticas */
    .estadisticas {
      display: flex; /* ✅ */
      justify-content: space-between; /* ✅ */
      text-align: center;
    }

    .stat {
      flex: 1; /* ✅ */
    }

    .stat h3 {
      font-size: 16px;
    }

    .stat p {
      font-size: 12px;
      color: gray;
    }

    /* Botones */
    .botones {
      display: flex; /* ✅ */
      justify-content: space-between; /* ✅ */
      gap: 10px; /* ✅ */
    }

    .botones button {
      flex: 1; /* ✅ */
      padding: 10px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }

    .seguir {
      background: #2563eb;
      color: white;
    }

    .mensaje {
      background: #e5e7eb;
    }

    /* Miniaturas */
    .miniaturas {
      display: flex; /* ✅ */
      gap: 10px; /* ✅ */
      flex-wrap: wrap; /* ✅ */
      justify-content: center;
    }

    .miniaturas img {
      width: 90px;
      height: 90px;
      border-radius: 10px;
      object-fit: cover;
    }

  </style>
</head>
<body>
  
  <div class="tarjeta">
    
    <!-- Header -->
    <div class="perfil-header">
      <img src="https://img.freepik.com/foto-gratis/mujer-cabello-largo-marron_1308-179038.jpg?semt=ais_hybrid&w=740&q=80" alt="avatar">
      <div class="info">
        <h2>valentina sierra</h2>
        <span>@valen.sierra</span>
      </div>
    </div>
    
    <!-- Bio -->
    <p class="bio">
      Desarrolladora web apasionada por el diseño y la tecnología.
    </p>
    
    <!-- Estadísticas -->
    <div class="estadisticas">
      <div class="stat">
        <h3>24</h3>
        <p>Proyectos</p>
      </div>
      <div class="stat">
        <h3>6.6K</h3>
        <p>Seguidores</p>
      </div>
      <div class="stat">
        <h3>300</h3>
        <p>Siguiendo</p>
      </div>
    </div>
    
    <!-- Botones -->
    <div class="botones">
      <button class="seguir">Seguir</button>
      <button class="mensaje">Mensaje</button>
    </div>
    
    <!-- Miniaturas -->
    <div class="miniaturas">
      <img src="data:image/jpeg;base64,">
      <img src="data:image/jpeg;base64,">
      <img src="data:image/jpeg;base64,">
    </div>
    
  </div>

</body>
</html>